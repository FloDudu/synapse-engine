# Clés API pour les services IA
# Obtenez votre clé sur https://www.mistral.ai/
MISTRAL_API_KEY="votre_clé_mistral_ici"

# Obtenez votre clé sur https://www.voyageai.com/
VOYAGE_API_KEY="votre_clé_voyage_ici"

# Clé secrète pour sécuriser l'API
APP_SECRET_KEY="votre_clé_secrète_pour_l'authentification_ici"

# --- Configuration Optionnelle ---

# Chemin vers la base de données vectorielle locale
VECTOR_DB_PATH="./chroma_db"

# Nom de la collection dans la base de données vectorielle
COLLECTION_NAME="synapse_knowledge"
